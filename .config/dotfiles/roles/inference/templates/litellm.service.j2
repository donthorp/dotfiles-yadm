[Unit]
Description=LiteLLM Proxy Server
After=network.target ollama.service

[Service]
Type=simple
ExecStart=/opt/litellm/bin/litellm --config /etc/litellm/config.yml \
  --host {{ litellm_listen_address }} --port {{ litellm_port }}
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
