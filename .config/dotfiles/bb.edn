;; Helper tasks for working with Ansible

{:tasks
 {:requires ([babashka.fs :as fs])

  ;; ── Maintenance ─────────────────────────────────────────────────────────────

  clean {:doc "Clean up temporary files"
         :task (when (fs/directory? ".ansible") (fs/delete-tree ".ansible"))}

  init {:doc "Pull requirements from Ansible Galaxy (clean cache first)"
        :depends [clean]
        :task (shell "ansible-galaxy install -r requirements.yml")}

  ;; ── Install ──────────────────────────────────────────────────────────────────

  install {:doc "Install all applicable plays for this machine (driven from inventory)"
           :task (shell "bash -c 'ansible-playbook main.yml -l $(hostname -s) 2>&1 | tee /tmp/ansible-run.log'")}

  install-common {:doc "Install common packages on this machine (base + neovim)"
                  :task (shell "bash -c 'ansible-playbook main.yml --tags common -l $(hostname -s) 2>&1 | tee /tmp/ansible-run.log'")}

  install-workstation {:doc "Install base + workstation packages on this machine"
                       :task (shell "bash -c 'ansible-playbook main.yml --tags common,workstation,gnome,cosmic -l $(hostname -s) 2>&1 | tee /tmp/ansible-run.log'")}

  install-inference {:doc "Install inference stack on this node"
                     :task (shell "bash -c 'ansible-playbook main.yml --tags common,inference -l $(hostname -s) 2>&1 | tee /tmp/ansible-run.log'")}

;; ── Test (requires Docker) ───────────────────────────────────────────────────
  ;; Only the common play (base + neovim roles) is exercised in Docker.
  ;; The workstation, gnome, and cosmic plays require a live desktop session.
  ;; The inference play requires ROCm-capable hardware.

  test-build {:doc "Build the Docker test image"
              :task (shell "docker build -t dotfiles-test -f test/Dockerfile .")}

  test-clean {:doc "Remove the Docker test image"
              :task (shell "docker rmi dotfiles-test")}

  test-syntax {:doc "Syntax check the full playbook in Docker"
               :depends [test-build]
               :task (shell (str "docker run --rm -v " (fs/cwd) ":/ansible dotfiles-test bash -c 'ansible-galaxy install -r requirements.yml --force && ansible-playbook --syntax-check -i test/inventory.yml main.yml'"))}

  test-check {:doc "Dry-run the common play in Docker (no changes applied)"
              :depends [test-build]
              :task (shell (str "docker run --rm -v " (fs/cwd) ":/ansible dotfiles-test bash -c 'ansible-galaxy install -r requirements.yml --force && ansible-playbook --check --tags common --skip-tags snap,flatpak,tailscale -i test/inventory.yml main.yml'"))}
 }}
